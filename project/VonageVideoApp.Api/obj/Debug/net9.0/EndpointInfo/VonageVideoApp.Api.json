{
  "openapi": "3.0.1",
  "info": {
    "title": "VonageVideoApp.Api",
    "version": "1.0"
  },
  "paths": {
    "/api/Video/session": {
      "post": {
        "tags": [
          "Video"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/SessionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Video/start-recording": {
      "post": {
        "tags": [
          "Video"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecordingRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RecordingRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RecordingRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Video/stop-recording": {
      "post": {
        "tags": [
          "Video"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StopRecordingRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/StopRecordingRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/StopRecordingRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RecordingRequest": {
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SessionRequest": {
        "type": "object",
        "properties": {
          "roomName": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "StopRecordingRequest": {
        "type": "object",
        "properties": {
          "archiveId": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}